{
  "name": "Flashpoint Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },

  "mounts": [
    "source=flashpoint-cargo-registry,target=/home/builder/.cargo/registry,type=volume",
    "source=flashpoint-cargo-git,target=/home/builder/.cargo/git,type=volume"
  ],

  "remoteUser": "builder",

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "probe-rs.probe-rs-debugger",
        "ms-vscode.hexeditor",
        "fill-labs.dependi"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "rust-analyzer.checkOnSave.command": "clippy",
        "rust-analyzer.cargo.allFeatures": true
      }
    }
  },

  "runArgs": [
    "--privileged",
    "--device=/dev/ttyUSB0",
    "--device=/dev/ttyACM0"
  ],

  "postCreateCommand": "echo 'source ~/flashpoint/scripts/export-esp.sh 2>/dev/null || true' >> ~/.bashrc && echo 'Dev container ready.'"
}
